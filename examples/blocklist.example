# Example blocklist configuration for UMRD
#
# Format: one cgroup path per line
# Paths in blocklist will NOT be reclaimed
#
# Example:
#   /sys/fs/cgroup/system.slice
#   /sys/fs/cgroup/user.slice

# Block UMRD's own cgroup (will be auto-generated)
/sys/fs/cgroup/umrd-

# Block system services
/sys/fs/cgroup/system.slice
/sys/fs/cgroup/user.slice
